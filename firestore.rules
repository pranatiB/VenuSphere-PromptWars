rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Venue data: public read, admin-only write
    match /zones/{zoneId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /crowd_density/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /queue_times/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /stalls/{stallId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /restrooms/{restroomId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Event data: public read, admin-only write
    match /event_schedule/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /announcements/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /alerts/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
                   && (!request.resource.data.keys().hasAny(['role', 'is_admin']))
                   && request.resource.data.keys().hasOnly(['dietary', 'accessibility', 'favorite_cuisines', 'seating_section', 'language', 'high_contrast', 'notifications_enabled', 'uid', 'createdAt', 'updatedAt']);

      match /sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /chat_history/{messageId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId
                     && (!request.resource.data.keys().hasAll(['content']) || request.resource.data.content.size() < 2000);
      }

      match /subscriptions/{subId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Crowd summary: public read
    match /crowd_summary/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
